rule filter_blast_and_create_list:
    input:
        blast_files = expand(out_dir + "/blast_100_l40/{sample}.txt", sample=a_samples_valid)
    output:
        blast_table = config["blast_table"],
        all_blast = config["blast_table_edited"]
    benchmark:
        os.path.join(out_dir, "logs_100_l40", "filter_blast_benchmark.txt")
    #priority: 5
    run:
        import pandas as pd
        from pathlib import Path

        all_rows = []
        for file_path in input.blast_files:
            sample_name = Path(file_path).stem
            try:
                df = pd.read_csv(file_path, sep=r'\s+', header=None)
            except pd.errors.EmptyDataError:
                print(f"[warning] File {file_path} is empty — skipping.")
                continue

            df_filtered = df[(df.iloc[:, 13] > 80) & (df.iloc[:, 12] >= 2000) & (df.iloc[:, 2] > 95)].copy()
            if df_filtered.empty:
                print(f"[info] No valid hits in {file_path} after filtering — skipping.")
                continue
            df_filtered.insert(0, "sample_file", sample_name + ".txt")
            all_rows.append(df_filtered)
        if not all_rows:
            print("[info] No BLAST results across all files — writing empty outputs.")
            pd.DataFrame().to_csv(output.blast_table, sep="\t", index=False, header=False)
            pd.DataFrame().to_csv(output.all_blast, index=False, header=False)
            return
        merged = pd.concat(all_rows, ignore_index=True)
        merged.drop_duplicates(subset=[1, 0], inplace=True)
        merged.to_csv(output.blast_table, sep="\t", header=False, index=False)
        merged['combined'] = merged['sample_file'].str.replace('.txt', '', regex=False) + '_' + merged.iloc[:, 1].astype(str)
        merged['combined'].to_csv(output.all_blast, index=False, header=False)

