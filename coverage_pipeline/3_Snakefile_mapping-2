rule fix_failed_samples_in_matrix:
    input:
        matrix=out_dir + "/coverage_100_l40/raw_matrix.tsv",
        failed_log=out_dir + "/coverage_100_l40/failed_samples.txt"
    output:
        matrix=config["result_matrix"]
    #benchmark:
    #    os.path.join(out_dir, "logs_100_l40", "failed_samples_benchmark.txt")
    run:
        import pandas as pd
        from pathlib import Path

        matrix_file = Path(input.matrix)
        failed_log = Path(input.failed_log)
        output_file = Path(output.matrix)

        df = pd.read_csv(matrix_file, sep='\t')

        if failed_log.exists():
            failed = [line.strip() for line in failed_log.open() if line.strip()]
            contig_col = df.columns[0]

            for f in failed:
                if f in df.columns:
                    df[f] = 0

        df.to_csv(output_file, sep='\t', index=False)

rule make_sample_names:
    output:
        before = out_dir + "/srr_ids_before_100_l40.txt",
        after = out_dir + "/srr_ids_after_100_l40.txt",
        filter = out_dir + "/srr_ids_before_after_100_l40.txt"
    params:
        dir_before = FASTQ_DIR_b,  # timepoint1_cleaned
        dir_after = FASTQ_DIR_a    # timepoint2_cleaned
    #benchmark:
     #   os.path.join(out_dir, "logs_100_l40", "make_sample_names_benchmark.txt")
    shell:
        """
        # Before timepoint (timepoint1)
        ls {params.dir_before}/*-cleaned_1.fastq.gz 2>/dev/null | \
        xargs -n1 basename | cut -d'-' -f1 | sort -u > {output.before} 
        # After timepoint (timepoint2)
        ls {params.dir_after}/*-cleaned_1.fastq.gz 2>/dev/null | \
        xargs -n1 basename | cut -d'-' -f1 | sort -u > {output.after}
        cat {output.before} {output.after} > {output.filter}
        """
