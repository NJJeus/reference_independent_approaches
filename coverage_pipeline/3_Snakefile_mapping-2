rule intersect_ids:
    input:
        ids=config["ids"],
        blast=config["blast_table_edited"]
    output:
        config["blast_table_end"]
    #benchmark:
     #   os.path.join(out_dir, "logs_100_l40", "intersect_ids_benchmark.txt")
    run:
        with open(input.ids) as f:
            contigs = [line.strip() for line in f]
        with open(input.blast) as f:
            blast_set = set(line.strip() for line in f)
        with open(output[0], "w") as fout:
            fout.write("contigs\treference_presence\n")
            for c in contigs:
                reference_flag = "1" if c in blast_set else "0"
                fout.write(f"{c}\t{reference_flag}\n")
